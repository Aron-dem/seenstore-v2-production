{
  "version": 2,
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": ".",
  "functions": {
    "api/server.mjs": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.mjs" },
    { "source": "/assets/(.*)", "destination": "/frontend/dist/public/assets/$1" },
    { "source": "/((?!api/).*)", "destination": "/frontend/dist/public/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
